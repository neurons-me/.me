{
  "entryPoints": ["./typedoc-entry.ts"],
  "out": "typedocs/api",
  "cleanOutputDir": true,
  "hostedBaseUrl": "https://neurons-me.github.io/.me/Typescript/typedocs/api/",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "sort": ["kind", "source-order"],
  "intentionallyNotExported": [
    "KernelMemory",
    "MEInspectResult",
    "MEExplainResult",
    "MESnapshot",
    "MESnapshotInput",
    "ReplayMemoryInput",
    "MePointer",
    "MeIdentityRef"
  ],
  "readme": "none"
}
