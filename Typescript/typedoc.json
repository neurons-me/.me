{
  "entryPoints": ["./typedoc-entry.ts"],
  "out": "docs/api",
  "plugin": ["typedoc-plugin-markdown"],
  "cleanOutputDir": false,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "sort": ["kind", "source-order"],
  "intentionallyNotExported": [
    "KernelMemory",
    "MEInspectResult",
    "MEExplainResult",
    "MESnapshot",
    "MESnapshotInput",
    "ReplayMemoryInput",
    "MePointer",
    "MeIdentityRef"
  ],
  "readme": "none"
}
